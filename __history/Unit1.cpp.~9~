void __fastcall TForm1::FormCreate(TObject *Sender)
{
	// Intentamos cargar el estado anterior del grafo desde el archivo fÚsico.
	// Si el archivo no existe (retorna ERROR), inicializamos el sistema con un set de datos de prueba (Hardcode).
	if (g.cargarArchivo().find("ERROR") != std::string::npos) {

		// Nodos base (Ciudades)
		g.agregarCiudad("Corrientes_Capital", 10, 10); // ID 0
		g.agregarCiudad("Goya", 20, 50);               // ID 1
		g.agregarCiudad("Mercedes", 50, 30);           // ID 2
		g.agregarCiudad("Paso_de_los_Libres", 80, 60); // ID 3
		g.agregarCiudad("Sauce", 70, 80);              // ID 4

		// Aristas base (Rutas) con sus respectivas distancias y nombres
		g.agregarConexion(1, 0, 225, "RN_12");
		g.agregarConexion(0, 2, 245, "RN_12-RN_123");
		g.agregarConexion(0, 3, 370, "RN_123-RN_14");
		g.agregarConexion(1, 2, 146, "RP_24");
		g.agregarConexion(1, 4, 171, "RP_23-RP_126");
		g.agregarConexion(2, 3, 127, "RN_119-RN_14");
		g.agregarConexion(2, 4, 161, "RN_119-RP_126");
		g.agregarConexion(3, 4, 267, "RN_14-RP_126");
	}
}

//---------------------------------------------------------------------------
// Botµn 1: Mostrar listado de ciudades
void __fastcall TForm1::Button1Click(TObject *Sender)
{
	memoSalida->Clear();
	memoSalida->Lines->Add("--- CIUDADES ---");

	// Recorremos el vector de ciudades y verificamos el estado (borrado lµgico)
	for (int i = 0; i < g.getCantidad(); i++) {
		Ciudad c = g.getCiudad(i);
		std::string info = std::to_string(c.getId()) + " - " + c.getNombre();

		// Feedback visual si la ciudad fue inhabilitada temporalmente
		if (!c.getEstado()) {
			info += " (inhabilitada)";
		}
		memoSalida->Lines->Add(info.c_str());
	}
}

//---------------------------------------------------------------------------
// Botµn 2: Mostrar la Matriz de Adyacencia
void __fastcall TForm1::Button2Click(TObject *Sender)
{
	memoSalida->Clear();
	memoSalida->Lines->Add("--- MATRIZ DE DISTANCIAS ---");

	for (int i = 0; i < g.getCantidad(); i++) {
		std::string fila = "";
		for (int j = 0; j < g.getCantidad(); j++) {
			int dist = g.getDistancia(i, j);

			// Enmascaramos el valor numÕrico de INF (999999) con la etiqueta visual "INF"
			if (dist == INF) {
				fila += "INF\t";
			} else {
				fila += std::to_string(dist) + "\t";
			}
		}
		memoSalida->Lines->Add(fila.c_str());
	}
}

//---------------------------------------------------------------------------
// Botµn 3: Calcular la ruta µptima usando el algoritmo de Dijkstra
void __fastcall TForm1::Button3Click(TObject *Sender)
{
	memoSalida->Clear();

	// Extracciµn de datos de la UI (Cajas de texto)
	int origen = StrToInt(Edit1->Text);
	int destino = StrToInt(Edit2->Text);

	// Invocaciµn del motor algorÚtmico
	std::string resultado = g.dijkstra(origen, destino);
	memoSalida->Lines->Add(resultado.c_str());
}

//---------------------------------------------------------------------------
// Botµn 4: Cortar Ruta (Desconexiµn temporal)
void __fastcall TForm1::Button4Click(TObject *Sender)
{
	memoSalida->Clear();
	int origen = StrToInt(Edit1->Text);
	int destino = StrToInt(Edit2->Text);

	// Ejecuta el borrado lµgico de la arista en ambas direcciones
	std::string resultado = g.cortarRuta(origen, destino);
	memoSalida->Lines->Add(resultado.c_str());
}

//---------------------------------------------------------------------------
// Botµn 5: Persistencia manual de datos
void __fastcall TForm1::Button5Click(TObject *Sender)
{
	memoSalida->Clear();

	// Genera o sobrescribe el archivo grafo.txt con el estado actual de la memoria
	std::string resultado = g.guardarArchivo();
	memoSalida->Lines->Add(resultado.c_str());
}

//---------------------------------------------------------------------------
// Botµn 6: Alta de nueva ciudad
void __fastcall TForm1::Button6Click(TObject *Sender)
{
	UnicodeString nombre = Edit3->Text;
	int x = StrToInt(Edit4->Text);
	int y = StrToInt(Edit5->Text);

	// Conversiµn explÚcita: VCL UnicodeString -> VCL AnsiString -> std::string (C++ EstÃndar)
	std::string nombreStd = AnsiString(nombre).c_str();
	std::string resultado = g.agregarCiudad(nombreStd, x, y);

	memoSalida->Lines->Add(resultado.c_str());
}

//---------------------------------------------------------------------------
// Botµn 7: Alta de nueva conexiµn (Feedback en ventana emergente)
void __fastcall TForm1::Button7Click(TObject *Sender)
{
	int origen = StrToInt(Edit3->Text);
	int destino = StrToInt(Edit4->Text);
	int distancia = StrToInt(Edit5->Text);

	// Se inyecta un nombre de ruta por defecto al no existir un input especÚfico en la UI
	std::string resultado = g.agregarConexion(origen, destino, distancia, "Ruta_Nueva");

	// Feedback mediante ventana modal
	ShowMessage(resultado.c_str());
}

